       RowBox[{"b", "(", 
        RowBox[{"1", ",", "4"}], ")"}], "\[Rule]", 
       RowBox[{
        RowBox[{"-", "V2"}], " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["\[CapitalDelta]2", "2"], "-", 
          RowBox[{"\[CapitalDelta]2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", " ", "\[CapitalDelta]3"}], "+", "3"}], ")"}]}], "+", 
          RowBox[{"\[CapitalDelta]3", " ", 
           RowBox[{"(", 
            RowBox[{"\[CapitalDelta]3", "+", "3"}], ")"}]}]}], ")"}]}]}]},
     {
      TemplateBox[{
        SubscriptBox["\"\[PartialD]\"", "V1"], 
