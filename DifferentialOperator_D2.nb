          "i"}], "<=", "j", "<="}], "..."}]}]}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ShowCoeffTable", "[", 
     RowBox[{"order_", ",", " ", "idxTuples_"}], "]"}], " ", ":=", "\n", "  ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "sym", ",", " ", "coeff", ",", " ", "label", ",", " ", "rows"}], "}"}],
       ",", "\n", "    ", 
