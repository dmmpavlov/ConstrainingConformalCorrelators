           ",", " ", "f"}], "}"}], "[", 
         RowBox[{"[", "order", "]"}], "]"}]}], ";", "\n", "    ", 
       RowBox[{"rows", " ", "=", " ", 
        RowBox[{"{", "}"}]}], ";", "\n", "    ", 
       RowBox[{"Do", "[", "\n", "      ", 
        RowBox[{
         RowBox[{
          RowBox[{"coeff", " ", "=", " ", 
           RowBox[{"Simplify", "[", 
            RowBox[{
             RowBox[{"sym", " ", "@@", " ", "idx"}], " ", "/.", " ", 
             "rules"}], "]"}]}], ";", "\n", "      ", 
          RowBox[{"If", "[", 
