                 RowBox[{"TraditionalForm", "[", "coeff", "]"}]}], "}"}]}], 
              "]"}]}]}], "\n", "      ", "]"}]}], ",", "\n", "      ", 
         RowBox[{"{", 
          RowBox[{"idx", ",", " ", "idxTuples"}], "}"}]}], "\n", "    ", 
