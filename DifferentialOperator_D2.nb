       RowBox[{
        FractionBox["1", "2"], " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["\[CapitalDelta]2", "2"], "-", 
          RowBox[{"2", " ", "\[CapitalDelta]2", " ", "\[CapitalDelta]3"}], 
          "+", 
          SuperscriptBox["\[CapitalDelta]3", "2"], "-", "1"}], ")"}]}]}]},
     {
      TemplateBox[{
        SubscriptBox["\"\[PartialD]\"", "V1"], 
