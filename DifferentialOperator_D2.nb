       "RowDefault"], 
      RowBox[{
       RowBox[{"b", "(", 
        RowBox[{"1", ",", "2"}], ")"}], "\[Rule]", "0"}]},
     {
      TemplateBox[{
        SubscriptBox["\"\[PartialD]\"", "V1"], 
