\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\>\"", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{
         "Print", "[", "\"\<Three-point function denominator:\>\"", "]"}], 
