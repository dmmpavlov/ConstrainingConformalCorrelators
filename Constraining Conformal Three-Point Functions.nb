\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\>\"", "]"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"\[HorizontalLine]\[HorizontalLine]", " ", "Step", " ", "1"}],
         ":", 
        RowBox[{
        "All", " ", "monomials", " ", 
         "\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]"}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"allMonomials", "=", 
       RowBox[{
        RowBox[{"Reap", "[", 
         RowBox[{"Do", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"a2", "=", 
             RowBox[{"s2", "-", "b12", "-", "b23"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"a3", "=", 
             RowBox[{"s3", "-", "b23", "-", "b31"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"a1", "+", "b12", "+", "b31"}], "==", "s1"}], "&&", 
               RowBox[{"a2", ">=", "0"}], "&&", 
               RowBox[{"a3", ">=", "0"}]}], ",", 
              RowBox[{"Sow", "[", 
               RowBox[{"{", 
                RowBox[{
                "a1", ",", "a2", ",", "a3", ",", "b12", ",", "b23", ",", 
                 "b31"}], "}"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"a1", ",", "0", ",", "s1"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"b12", ",", "0", ",", 
             RowBox[{"Min", "[", 
              RowBox[{
               RowBox[{"s1", "-", "a1"}], ",", "s2"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"b23", ",", "0", ",", 
             RowBox[{"s2", "-", "b12"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"b31", ",", "0", ",", 
             RowBox[{"s1", "-", "a1", "-", "b12"}]}], "}"}]}], "]"}], "]"}], 
        "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"allMonomials", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"allMonomials", "==", 
          RowBox[{"{", "}"}]}], ",", 
         RowBox[{"{", "}"}], ",", 
         RowBox[{"First", "[", "allMonomials", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"n0", "=", 
       RowBox[{"Length", "[", "allMonomials", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"verbose", ",", 
        RowBox[{
         RowBox[{
         "Print", "[", 
          "\"\<Step 1 \[LongDash] Numerator monomials satisfying \
\[Alpha]-constraints:\>\"", "]"}], ";", "\[IndentingNewLine]", 
