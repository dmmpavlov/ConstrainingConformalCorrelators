\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"FormatMonomial", "[", "e_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"terms", ",", "symbols"}], "}"}], ",", 
       RowBox[{
        RowBox[{"symbols", "=", 
         RowBox[{"{", 
          RowBox[{
          "\"\<V\:2081\>\"", ",", "\"\<V\:2082\>\"", ",", "\"\<V\:2083\>\"", 
           ",", "\"\<H\:2081\:2082\>\"", ",", "\"\<H\:2082\:2083\>\"", ",", 
           "\"\<H\:2083\:2081\>\""}], "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"terms", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Which", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"e", "[", 
               RowBox[{"[", "k", "]"}], "]"}], "==", "0"}], ",", "Nothing", 
             ",", 
             RowBox[{
              RowBox[{"e", "[", 
               RowBox[{"[", "k", "]"}], "]"}], "==", "1"}], ",", 
             RowBox[{"symbols", "[", 
              RowBox[{"[", "k", "]"}], "]"}], ",", "True", ",", 
             RowBox[{"DisplayForm", "[", 
              RowBox[{"SuperscriptBox", "[", 
               RowBox[{
                RowBox[{"symbols", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], ",", 
                RowBox[{"ToString", "[", 
                 RowBox[{"e", "[", 
                  RowBox[{"[", "k", "]"}], "]"}], "]"}]}], "]"}], "]"}]}], 
            "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "6"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"terms", "===", 
           RowBox[{"{", "}"}]}], ",", "\"\<1\>\"", ",", 
          RowBox[{"Row", "[", 
           RowBox[{"terms", ",", "\"\< \>\""}], "]"}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"FormatLinearCombination", "[", 
      RowBox[{"coeffs_", ",", "monomials_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "terms", "}"}], ",", 
       RowBox[{
        RowBox[{"terms", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"coeffs", "[", 
               RowBox[{"[", "k", "]"}], "]"}], "==", "0"}], ",", "Nothing", 
             ",", 
             RowBox[{"Row", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"coeffs", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], "==", "1"}], ",", 
                  "\"\<\>\"", ",", 
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"coeffs", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], "==", 
                    RowBox[{"-", "1"}]}], ",", "\"\<-\>\"", ",", 
                    RowBox[{"Row", "[", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"coeffs", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], ",", "\"\< \>\""}], "}"}],
                     "]"}]}], "]"}]}], "]"}], ",", 
                RowBox[{"FormatMonomial", "[", 
                 RowBox[{"monomials", "[", 
                  RowBox[{"[", "k", "]"}], "]"}], "]"}]}], "}"}], "]"}]}], 
            "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", 
             RowBox[{"Length", "[", "coeffs", "]"}]}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"terms", "===", 
           RowBox[{"{", "}"}]}], ",", "\"\<0\>\"", ",", 
          RowBox[{"Row", "[", 
           RowBox[{"terms", ",", "\"\< + \>\""}], "]"}]}], "]"}]}]}], "]"}]}],
     ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"FormatFraction", "[", 
      RowBox[{"\[Tau]12_", ",", "\[Tau]23_", ",", "\[Tau]31_"}], "]"}], ":=", 
     
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "FormatFactor", "}"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"FormatFactor", "[", 
          RowBox[{"sub_", ",", "\[Tau]_"}], "]"}], ":=", 
