      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"bosePair", "=!=", "None"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"perms", ",", "symLabel"}], "}"}], "=", 
          RowBox[{"Which", "[", 
           RowBox[{
            RowBox[{"bosePair", "===", "Full"}], ",", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"!", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"s1", "==", "s2", "==", "s3"}], "&&", 
                  RowBox[{
                  "\[CapitalDelta]1", "==", "\[CapitalDelta]2", "==", 
                   "\[CapitalDelta]3"}]}], ")"}]}], ",", 
               RowBox[{
                RowBox[{
                "Print", "[", 
                 "\"\<\[WarningSign] Full S3 requires all three operators \
identical.\>\"", "]"}], ";", "\[IndentingNewLine]", 
                RowBox[{"Return", "[", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"IdentityMatrix", "[", "n1", "]"}], ",", 
                   "gramReduced"}], "}"}], "]"}]}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"S3Elements", "[", "]"}], ",", 
               "\"\<full S3 (1\[LeftRightArrow]2\[LeftRightArrow]3)\>\""}], 
              "}"}]}], ",", 
            RowBox[{
             RowBox[{"ListQ", "[", "bosePair", "]"}], "&&", 
             RowBox[{
              RowBox[{"Length", "[", "bosePair", "]"}], "==", "2"}]}], ",", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"spins", "[", 
                  RowBox[{"[", 
                   RowBox[{"bosePair", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "!=", 
                 RowBox[{"spins", "[", 
                  RowBox[{"[", 
                   RowBox[{"bosePair", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], "]"}], "]"}]}], "||", 
                RowBox[{
                 RowBox[{"deltas", "[", 
                  RowBox[{"[", 
                   RowBox[{"bosePair", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "!=", 
                 RowBox[{"deltas", "[", 
                  RowBox[{"[", 
                   RowBox[{"bosePair", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], "]"}], "]"}]}]}], ",", 
               RowBox[{
                RowBox[{"Print", "[", 
