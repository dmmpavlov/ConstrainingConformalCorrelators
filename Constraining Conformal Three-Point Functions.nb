           RowBox[{"\[Tau]", "==", "1"}], ",", 
           RowBox[{"DisplayForm", "[", 
            RowBox[{"SubscriptBox", "[", 
             RowBox[{"\"\<P\>\"", ",", "sub"}], "]"}], "]"}], ",", "True", 
           ",", 
           RowBox[{"DisplayForm", "[", 
            RowBox[{"SuperscriptBox", "[", 
             RowBox[{
              RowBox[{"SubscriptBox", "[", 
               RowBox[{"\"\<P\>\"", ",", "sub"}], "]"}], ",", 
              RowBox[{"ToString", "[", "\[Tau]", "]"}]}], "]"}], "]"}]}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Row", "[", 
         RowBox[{"{", 
          RowBox[{
          "\"\<\[LeftAngleBracket]O\:2081O\:2082O\:2083\[RightAngleBracket]\>\
\"", ",", "\"\< = (numerator) / ( \>\"", ",", 
           RowBox[{"FormatFactor", "[", 
            RowBox[{"\"\<12\>\"", ",", "\[Tau]12"}], "]"}], ",", "\"\< \>\"", 
           ",", 
           RowBox[{"FormatFactor", "[", 
            RowBox[{"\"\<23\>\"", ",", "\[Tau]23"}], "]"}], ",", "\"\< \>\"", 
           ",", 
           RowBox[{"FormatFactor", "[", 
            RowBox[{"\"\<31\>\"", ",", "\[Tau]31"}], "]"}], ",", 
           "\"\< )\>\""}], "}"}], "]"}]}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PrintMonomials", "[", "monomials_", "]"}], ":=", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<  [\>\"", ",", "k", ",", "\"\<]  \>\"", ",", 
         RowBox[{"FormatMonomial", "[", 
          RowBox[{"monomials", "[", 
           RowBox[{"[", "k", "]"}], "]"}], "]"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", 
         RowBox[{"Length", "[", "monomials", "]"}]}], "}"}]}], "]"}]}], ";"}],
    "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PrintBoseStructures", "[", 
      RowBox[{"basis_", ",", "monomials_"}], "]"}], ":=", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<  [\>\"", ",", "k", ",", "\"\<]  \>\"", ",", 
         RowBox[{"FormatLinearCombination", "[", 
          RowBox[{
           RowBox[{"basis", "[", 
            RowBox[{"[", "k", "]"}], "]"}], ",", "monomials"}], "]"}]}], 
        "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", 
         RowBox[{"Length", "[", "basis", "]"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "\[HorizontalLine]\[HorizontalLine]", " ", "Gram", " ", "constraint", " ",
      "reduction", " ", 
     "\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]"}], 
    "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GramReduce", "[", "monomials_", "]"}], ":=", 
     RowBox[{"Select", "[", 
      RowBox[{"monomials", ",", 
       RowBox[{
        RowBox[{"Not", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "4", "]"}], "]"}], ">=", "1"}], "&&", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "5", "]"}], "]"}], ">=", "1"}], "&&", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "6", "]"}], "]"}], ">=", "1"}]}], "]"}], "&"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "\[HorizontalLine]\[HorizontalLine]", " ", "Bose", " ", "symmetry", " ", 
     "\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]"}], 
    "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Sign", " ", "for", " ", "V_i", " ", "under", " ", "permutation", " ", 
      "sigma", " ", "is", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{
        "number", " ", "of", " ", "transpositions", " ", "that", " ", "move", 
         " ", "i"}], ")"}]}]}], ",", 
     RowBox[{"but", " ", 
      RowBox[{"let", "'"}], "s", " ", "just", " ", "define", " ", 
      "directly"}]}], "*)"}], 
   RowBox[{
    RowBox[{
     RowBox[{"PermutationVSign", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}], "]"}], "=", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], ";"}], "  ", 
   RowBox[{"(*", "identity", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"PermutationVSign", "[", 
      RowBox[{"{", 
       RowBox[{"2", ",", "1", ",", "3"}], "}"}], "]"}], "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", 
       RowBox[{"-", "1"}], ",", 
       RowBox[{"-", "1"}]}], "}"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"swap", " ", "1"}], "<->", "2"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"PermutationVSign", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", "3", ",", "2"}], "}"}], "]"}], "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", 
       RowBox[{"-", "1"}], ",", 
       RowBox[{"-", "1"}]}], "}"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"swap", " ", "2"}], "<->", "3"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"PermutationVSign", "[", 
      RowBox[{"{", 
       RowBox[{"3", ",", "2", ",", "1"}], "}"}], "]"}], "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", 
       RowBox[{"-", "1"}], ",", 
       RowBox[{"-", "1"}]}], "}"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"swap", " ", "1"}], "<->", "3"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"PermutationVSign", "[", 
      RowBox[{"{", 
       RowBox[{"2", ",", "3", ",", "1"}], "}"}], "]"}], "=", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"cyclic", " ", "1"}], "->", 
     RowBox[{"2", "->", 
      RowBox[{"3", "->", "1"}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"PermutationVSign", "[", 
      RowBox[{"{", 
       RowBox[{"3", ",", "1", ",", "2"}], "}"}], "]"}], "=", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"cyclic", " ", "1"}], "->", 
     RowBox[{"3", "->", 
      RowBox[{"2", "->", "1"}]}]}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"BoseTransformPerm", "[", 
      RowBox[{"exp_", ",", "perm_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "a", ",", "b", ",", "na", ",", "nb", ",", "pairs", ",", "pairIndex", 
         ",", "sign", ",", "vSigns"}], "}"}], ",", 
       RowBox[{
        RowBox[{"a", "=", 
         RowBox[{"exp", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "3"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"b", "=", 
         RowBox[{"exp", "[", 
          RowBox[{"[", 
           RowBox[{"4", ";;", "6"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"pairs", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", "2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"2", ",", "3"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"3", ",", "1"}], "}"}]}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"pairIndex", "[", 
          RowBox[{"{", 
           RowBox[{"p_", ",", "q_"}], "}"}], "]"}], ":=", 
         RowBox[{"Which", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Sort", "[", 
             RowBox[{"{", 
