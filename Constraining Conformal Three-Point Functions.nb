         RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";", "\[IndentingNewLine]", 
         
         RowBox[{"PrintMonomials", "[", "allMonomials", "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
         "Print", "[", 
          "\"\<\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\>\"", "]"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
