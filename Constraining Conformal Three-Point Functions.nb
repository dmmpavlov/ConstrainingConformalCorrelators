Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "\[HorizontalLine]\[HorizontalLine]", " ", "Formatting", " ", "helpers", 
    " ", "\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
