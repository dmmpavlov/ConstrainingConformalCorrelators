Notebook[{

Cell[CellGroupData[{
Cell["Constraining Conformal Three-Point Functions", "Title",
 CellChangeTimes->{{3.988859522739306*^9, 3.988859529020998*^9}, {
  3.988864866498529*^9, 
  3.9888648708142033`*^9}},ExpressionUUID->"ae8e018e-80d7-4840-ab2e-\
312ffc04d839"],

Cell[TextData[StyleBox["Nathan Meurrens (contact: n.meurrens@uva.nl)", \
"Author"]], "Subtitle",
 CellChangeTimes->{{3.9888595342753057`*^9, 3.988859537867832*^9}, {
  3.9888598238151207`*^9, 3.988859826952869*^9}, {3.988860830892537*^9, 
  3.988860871095365*^9}},ExpressionUUID->"e392a0ae-4a2b-4a70-a477-\
748dd70f3893"],

Cell[TextData[{
 "This notebook accompanies the paper ",
 StyleBox["Constraining Conformal Correlators",
  FontWeight->"Bold"],
 " by ",
 StyleBox["Viktoriia Borovik, Claire de Korte, Nathan Meurrens, Dmitrii \
Pavlov",
  FontWeight->"Bold"],
 " (arXiv : [XXXX . XXXXX]). It provides a Mathematica implementation for \
constructing the independent tensor structures appearing in conformal \
three-point functions of spinning operators written in embedding space \
structures. Given spins ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["s", "1"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3a50ab5a-6b7c-4fcd-ae3e-3157c325a08e"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["s", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "95689c11-5c3d-48fc-bed0-c099aa355a0d"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["s", "3"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5cd9f5cb-c1d4-46b6-90b5-5db9d9fb81f1"],
 "), conformal dimensions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["\[CapitalDelta]", "1"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "66140cef-4b14-4ec2-a9d6-ed2a52b7e823"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalDelta]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d1f82af5-e51c-4b2f-88f6-f4c974b76017"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalDelta]", "3"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b18a4ecf-46e3-4187-bc0b-4b17d576798f"],
 "), and spacetime dimension ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6b815ca5-a0c7-4bc2-844f-6433f29cff85"],
 ", the main function `ThreePointStructures` systematically constructs all \
allowed numerator structures, imposes Gram constraint reduction (for ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c2e42c50-0733-4093-808d-ba71eb61aed3"],
 " = 3), Bose symmetry, and conservation constraints (both single \
conservation ",
 Cell[BoxData[
  FormBox["\[CapitalDelta]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b67665c6-19e1-428a-a645-b34af81fc04c"],
 " = ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f1987cd0-f1b3-4a71-a65c-8ef9419befed"],
 " + ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0d002ab7-f2ca-4634-b704-40b6a5657386"],
 " \[Minus] 2 and double conservation ",
 Cell[BoxData[
  FormBox["\[CapitalDelta]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "47668943-f480-4eb0-834d-7eabb0900d5f"],
 " = ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8fe05962-00c0-4564-93ad-615ab157617f"],
 " + ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e4b192fd-a1db-44c0-b283-9be228a1747f"],
 " \[Minus] 3). Conservation for lower values of depth ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "65a95509-2de1-45e8-b8c6-a2e71b4b3f29"],
 " is not implemented. \n\nThe solution files D1Solution.m and D2Solution.m, \
which encode the divergence operators acting on numerator written solely in \
terms of embedding space structures, must be placed in the same directory as \
this notebook before running. The notebook was written and tested in \
Mathematica 14.1 .0 .0 . Compatibility with earlier versions is not \
guaranteed, in particular due to the use of SelectFirst, Nothing, and \
DisplayForm with SuperscriptBox and SubscriptBox."
}], "Text",
 CellChangeTimes->{{3.988861376327305*^9, 3.988861399394799*^9}, {
  3.988861450055806*^9, 3.988861706107782*^9}, {3.988861821302314*^9, 
  3.988861904181765*^9}},ExpressionUUID->"ca1ea1be-e2c4-49a4-b8f9-\
259f6247170c"],

