      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"\[HorizontalLine]\[HorizontalLine]", " ", "Step", " ", "3"}],
         ":", 
        RowBox[{
        "Bose", " ", "symmetry", " ", 
