           RowBox[{"gramReduced", ",", "perms"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"n2", "=", 
          RowBox[{"Length", "[", "boseBasis", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"currentStructures", "=", "boseBasis"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{"verbose", ",", 
           RowBox[{
            RowBox[{"Print", "[", 
             RowBox[{
             "\"\<Step 3 \[LongDash] Bose symmetry (\>\"", ",", "symLabel", 
