         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{"verbose", ",", 
           RowBox[{
            RowBox[{
            "Print", "[", 
             "\"\<Step 2 \[LongDash] Gram constraint reduction (d=3):\>\"", 
             "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
             "\"\<  \>\"", ",", "n0", ",", "\"\< \[Rule] \>\"", ",", "n1", 
              ",", "\"\< structures  (removed \>\"", ",", 
              RowBox[{"n0", "-", "n1"}], ",", "\"\<).\>\""}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"PrintMonomials", "[", "gramReduced", "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{
            "Print", "[", 
