                  RowBox[{"bosePair", "[", 
                   RowBox[{"[", "2", "]"}], "]"}], ",", 
                  "\"\< have different (s,\[CapitalDelta]).\>\""}], "]"}], 
                ";", "\[IndentingNewLine]", 
                RowBox[{"Return", "[", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"IdentityMatrix", "[", "n1", "]"}], ",", 
                   "gramReduced"}], "}"}], "]"}]}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"TranspositionSubgroup", "[", "bosePair", "]"}], ",", 
               RowBox[{"\"\<swap \>\"", "<>", 
                RowBox[{"ToString", "[", 
                 RowBox[{"bosePair", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}], "<>", 
                "\"\< \[LeftRightArrow] \>\"", "<>", 
                RowBox[{"ToString", "[", 
                 RowBox[{"bosePair", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], "]"}]}]}], "}"}]}], ",", 
