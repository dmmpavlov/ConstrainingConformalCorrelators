                 "\"\<single\>\"", ",", "d", ",", "\[CapitalDelta]1", ",", 
                 "\[CapitalDelta]2", ",", "\[CapitalDelta]3", ",", 
                 "verbose"}], "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"stepCount", "++"}]}], ",", 
             RowBox[{
              RowBox[{"\[CapitalDelta]i", "===", 
               RowBox[{"d", "+", "si", "-", "3"}]}], "&&", 
              RowBox[{"si", ">=", "2"}]}], ",", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{"verbose", ",", 
                RowBox[{
                 RowBox[{"Print", "[", 
                  RowBox[{
                  "\"\<Step \>\"", ",", "stepCount", ",", 
                   "\"\< \[LongDash] Double conservation of operator \>\"", 
                   ",", "i", ",", "\"\< (\[CapitalDelta] = d + s - 3):\>\""}],
                   "]"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"currentStructures", "=", 
               RowBox[{"ConservationReduce", "[", 
                RowBox[{
                "currentStructures", ",", "currentMonomials", ",", "i", ",", 
                 "\"\<double\>\"", ",", "d", ",", "\[CapitalDelta]1", ",", 
                 "\[CapitalDelta]2", ",", "\[CapitalDelta]3", ",", 
                 "verbose"}], "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"stepCount", "++"}]}], ",", 
             RowBox[{
              RowBox[{"\[CapitalDelta]i", "===", 
               RowBox[{"d", "+", "si", "-", "3"}]}], "&&", 
              RowBox[{"si", "<", "2"}]}], ",", 
             RowBox[{"Print", "[", 
              RowBox[{
              "\"\<\[WarningSign] Operator \>\"", ",", "i", ",", 
               "\"\< cannot be doubly conserved: need s \[GreaterEqual] 2, \>\
\"", ",", "\"\<but s = \>\"", ",", "si", ",", "\"\<.\>\""}], "]"}], ",", 
             "True", ",", 
             RowBox[{"Print", "[", 
              RowBox[{
              "\"\<\[WarningSign] Operator \>\"", ",", "i", ",", 
               "\"\< is not conserved: \[CapitalDelta]\>\"", ",", "i", ",", 
               "\"\< = \>\"", ",", "\[CapitalDelta]i", ",", 
               "\"\<, need d + s - 2 = \>\"", ",", 
