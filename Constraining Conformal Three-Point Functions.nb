            RowBox[{"Print", "[", 
             RowBox[{
             "\"\<  \>\"", ",", "n1", ",", "\"\< \[Rule] \>\"", ",", "n2", 
              ",", "\"\< structures  (removed \>\"", ",", 
              RowBox[{"n1", "-", "n2"}], ",", "\"\<).\>\""}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"PrintBoseStructures", "[", 
             RowBox[{"boseBasis", ",", "gramReduced"}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{
            "Print", "[", 
             "\"\<\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\:2501\
\:2501\:2501\>\"", "]"}], ";"}]}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"n2", "=", "n1"}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{
         "\[HorizontalLine]\[HorizontalLine]", " ", "Step", " ", "4"}], "+"}],
         ":", 
        RowBox[{
        "Conservation", " ", 
         "\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\
\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]"}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"stepCount", "=", "4"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MemberQ", "[", 
           RowBox[{"conserved", ",", "i"}], "]"}], ",", 
          RowBox[{
           RowBox[{"si", "=", 
            RowBox[{"spins", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"\[CapitalDelta]i", "=", 
            RowBox[{"deltas", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"Which", "[", 
            RowBox[{
             RowBox[{"\[CapitalDelta]i", "===", 
              RowBox[{"d", "+", "si", "-", "2"}]}], ",", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{"verbose", ",", 
                RowBox[{
                 RowBox[{"Print", "[", 
                  RowBox[{
                  "\"\<Step \>\"", ",", "stepCount", ",", 
                   "\"\< \[LongDash] Single conservation of operator \>\"", 
                   ",", "i", ",", "\"\< (\[CapitalDelta] = d + s - 2):\>\""}],
                   "]"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"currentStructures", "=", 
               RowBox[{"ConservationReduce", "[", 
                RowBox[{
