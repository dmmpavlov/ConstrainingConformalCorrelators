Cell[TextData[{
 "We want to determine the differential operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PartialD]", 
    RowBox[{"\[CenterDot]", "D"}]}], TraditionalForm]],ExpressionUUID->
  "64191b38-baf6-4b77-b086-ebb274fad87c"],
 " in terms of derivatives with respect to embedding space structures. This \
operator has to be of order 3. We therefore write down the most general \
Ansatz:"
}], "Text",
