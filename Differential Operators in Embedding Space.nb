Cell[TextData[{
 "We substitute some values for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["s", "1"], ",", " ", 
     SubscriptBox["s", "2"], ",", " ", 
     RowBox[{
      SubscriptBox["s", 
       RowBox[{"3", ","}]], 
      SubscriptBox["h", "12"]}], ",", " ", 
     SubscriptBox["h", "23"], ",", " ", 
     SubscriptBox["h", "31"]}]}], TraditionalForm]],ExpressionUUID->
  "3924958a-5e1f-44d0-a4ee-68cbeb303759"],
 "} and make a table of LHS = RHS for all of these values, and solve the \
system for the free coefficients in the differential operator Ansatz."
}], "Text",
 CellChangeTimes->{{3.9833348575740633`*^9, 
  3.98333496545579*^9}},ExpressionUUID->"21106f17-7777-462a-9d5d-\
790842e595fd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"vals", " ", "=", " ", 
   RowBox[{
    RowBox[{"Reap", "[", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"s1", ">=", 
             RowBox[{"h12", "+", "h31"}]}], "&&", 
            RowBox[{"s2", ">=", 
             RowBox[{"h12", "+", "h23"}]}], "&&", 
            RowBox[{"s3", ">=", 
             RowBox[{"h23", "+", "h31"}]}]}], ",", 
           RowBox[{"Sow", "[", 
            RowBox[{"{", 
             RowBox[{
             "s1", ",", "s2", ",", "s3", ",", "h12", ",", "h23", ",", "h31"}],
              "}"}], "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"h12", ",", "0", ",", "3"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"h23", ",", "0", ",", "3"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"h31", ",", "0", ",", "3"}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"s1", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"s2", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"s3", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rules", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"s1", "->", 
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{"s2", "->", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{"s3", "->", 
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], ",", " ", 
        RowBox[{"h12", "->", 
         RowBox[{"#", "[", 
          RowBox[{"[", "4", "]"}], "]"}]}], ",", " ", 
        RowBox[{"h23", "->", 
         RowBox[{"#", "[", 
          RowBox[{"[", "5", "]"}], "]"}]}], ",", " ", 
        RowBox[{"h31", "->", 
