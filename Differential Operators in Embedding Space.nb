Cell[TextData[{
 "As we demonstrated in the general d case, the expression is independent on \
the residual embedding space inner products iff ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalDelta]", "1"], " ", "=", " ", 
    RowBox[{
     RowBox[{"d", "-", "1", "+", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["s", "1"], "-", "2"}], ")"}]}], " ", "=", " ", 
     RowBox[{
      SubscriptBox["s", "1"], "."}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "43ed654a-6437-43f1-87cd-f96454949e0f"],
 " We can thus put P1Z2 = P2Z1 = P2Z3 = 0."
}], "Text",
 CellChangeTimes->{{3.987639982871462*^9, 
  3.987640093228544*^9}},ExpressionUUID->"e565544f-79e7-4ed9-8be5-\
5497f910e6c2"],

