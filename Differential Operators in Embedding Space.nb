Cell[TextData[{
 "Unsurprisingly, the powers in the denominator don\[CloseCurlyQuote]t change \
as one take a derivative. This is because it depends on the sum ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["s", "1"], "+", 
    SubscriptBox["\[CapitalDelta]", "1"]}], TraditionalForm]],ExpressionUUID->
  "9552ba3c-d7da-4acc-9c2f-585f23121953"],
 ", which is invariant under taking a divergence, as this shifts ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["s", "1"], TraditionalForm]],ExpressionUUID->
  "833b9162-3226-4962-94d6-0acea0bdde1f"],
 Cell[BoxData[
  FormBox[
   RowBox[{"->", 
    RowBox[{
     SubscriptBox["s", "1"], "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "09073f8d-f843-4d95-92b0-9093c0f625dd"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalDelta]", "1"], "->", 
    RowBox[{
     SubscriptBox["\[CapitalDelta]", "1"], "+", "1"}]}], TraditionalForm]],
  ExpressionUUID->"20aace18-bd60-45eb-89d1-f2420e29ccf4"],
 "."
}], "Text",
 CellChangeTimes->{{3.983249510495469*^9, 3.983249641656295*^9}, {
  3.9840345049605627`*^9, 
  3.984034505042983*^9}},ExpressionUUID->"2ff7576c-d2ac-4777-8c8d-\
