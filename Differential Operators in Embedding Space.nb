Cell["\<\
This seems to imply that there is no term in the differential operator that \
is of first order in derivatives.\
\>", "Text",
 CellChangeTimes->{{3.987646574599689*^9, 
  3.98764660006394*^9}},ExpressionUUID->"2eb173d5-d5c1-473e-8aea-\
78524f0e56c7"],

Cell[CellGroupData[{

Cell["Tedious Calculation", "Subsubsection",
 CellChangeTimes->{{3.987645083027606*^9, 
  3.987645089168971*^9}},ExpressionUUID->"993607d7-0c6c-49c3-be44-\
a0c545ea6496"],

Cell[TextData[{
 "Here we evaluate the constraint on a bunch of configurations of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["s", "1"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "54ae00cd-57c6-4f23-bbff-bf31ce0505dd"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["s", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ef9bc9af-cfa2-4bde-be1c-20761961f61a"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["s", "3"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "60a91822-7552-45c6-bfd4-215bd0d93fc2"],
 "}. We solve them piece by piece to finally obtain expressions for the free \
coefficients in the differential operator ansatz."
}], "Text",
 CellChangeTimes->{{3.987645722508654*^9, 
  3.9876458456706867`*^9}},ExpressionUUID->"0cec0452-617f-4a07-9ec5-\
d06df056bb86"],

Cell[TextData[{
 "We see that the three-point function indeed has the right scaling of a \
correlator with the first operator of spin = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["s", "1"], "-", "2"}], TraditionalForm]],ExpressionUUID->
  "46827f65-c4e7-4102-ad79-85dc4b344756"],
 "."
}], "Text",
 CellChangeTimes->{{3.9832510341130257`*^9, 3.983251085499116*^9}, {
  3.98764091274892*^9, 
  3.987640913002749*^9}},ExpressionUUID->"9956a046-574a-4645-b0fc-\
ca9476620589"],

