 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[PartialD]", "2"], 
     SubscriptBox["O", "1"]}], " ", "=", " ", "0."}], TraditionalForm]],
  ExpressionUUID->"2ac1c881-fb32-47c7-96b3-96c58b31fcfc"],
