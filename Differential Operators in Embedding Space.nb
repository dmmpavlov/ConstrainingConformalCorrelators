Cell[TextData[{
 "We see that the three-point function indeed has the right scaling of a \
correlator with the first operator of spin = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["s", "1"], "-", "1"}], TraditionalForm]],ExpressionUUID->
  "444fb5f1-f766-4ba6-bb07-cb83c947043e"],
